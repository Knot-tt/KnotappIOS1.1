# supabase/.env.example
# ✅  Committed to git — contains no real secrets.
#
# Setup:
#   1. Copy to supabase/.env
#   2. Fill in real values
#   3. Run: supabase secrets set --env-file supabase/.env
#      (or set each secret individually via the Supabase Dashboard →
#       Edge Functions → Manage secrets)
#
# supabase/.env is gitignored — never commit it.

# ── Stripe ────────────────────────────────────────────────────────────────────
# Supabase Dashboard → Edge Functions → Manage secrets
# OR: stripe listen → your secret key from stripe.com/dashboard/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ── Supabase (auto-injected into Edge Functions, do not set manually) ─────────
# These are provided automatically by the Supabase runtime:
#   SUPABASE_URL               — your project URL
#   SUPABASE_ANON_KEY          — public anon key (safe for client use)
#   SUPABASE_SERVICE_ROLE_KEY  — ⚠️  full admin access, server-only, never expose

# ── Notes ─────────────────────────────────────────────────────────────────────
# The SERVICE_ROLE_KEY grants full database access bypassing RLS.
# It must never be included in iOS app code or any client-side code.
# It is only used inside Edge Functions via Deno.env.get("SUPABASE_SERVICE_ROLE_KEY").
