<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Knot</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Knot</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.1</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>personal.Knot.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>knot</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>104</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>maps</string>
		<string>mailto</string>
		<string>tel</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Knot uses your camera so you can take photos to share in chats and add to marketplace listings, and to scan card details when you add a payment method or set up payouts.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Knot can use Face ID to quickly confirm sensitive actions like payments and account changes.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Knot uses your microphone to record video in the in-app camera.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Knot needs permission to save photos you receive in chats to your camera roll.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Knot needs access to your photos so you can set a profile picture, add a Knot cover photo, share images in chats, and upload photos for marketplace listings.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
